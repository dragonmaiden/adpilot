# ═══════════════════════════════════════════
# AdPilot — Environment Variables
# Copy to .env for local dev, or set in Render Dashboard
# ═══════════════════════════════════════════

# Meta Ads API (required)
META_ACCESS_TOKEN=your_meta_long_lived_token_here
META_AD_ACCOUNT_ID=act_1407071387528879
META_BUSINESS_ID=1037680327881084

# Imweb API (required)
IMWEB_CLIENT_ID=your_imweb_client_id
IMWEB_CLIENT_SECRET=your_imweb_client_secret
IMWEB_SITE_CODE=S20260108741f7ad4afc71
IMWEB_UNIT_CODE=u20260108695f4cab3dea1
IMWEB_REFRESH_TOKEN=your_imweb_refresh_token_for_first_deploy

# Telegram Bot (required)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id
# Optional: if unset, spoiler-wrapped customer details use TELEGRAM_CHAT_ID.
TELEGRAM_PRIVATE_CHAT_ID=
TELEGRAM_REQUEST_TIMEOUT_MS=10000

# Google Sheets append-only COGS autofill (optional, required for auto-writing new rows)
COGS_GOOGLE_CLIENT_EMAIL=your_google_service_account_email
COGS_GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Server
PORT=3001
DATA_DIR=./server/data
SCAN_INTERVAL_MINUTES=30
